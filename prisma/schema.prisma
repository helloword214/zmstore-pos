  grossPay                   Decimal  @default(0) @db.Decimal(12, 2)
  chargeDeductionAmount      Decimal  @default(0) @db.Decimal(12, 2)
  statutoryDeductionAmount   Decimal  @default(0) @db.Decimal(12, 2)
  totalDeductions            Decimal  @default(0) @db.Decimal(12, 2)
  netPay                     Decimal  @default(0) @db.Decimal(12, 2)
  policySnapshot             Json?
  additionSnapshot           Json?
