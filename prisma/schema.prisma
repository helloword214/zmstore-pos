  updatedAt        DateTime  @updatedAt

  employee  Employee @relation("EmployeeStatutoryDeductionProfilesOnEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("EmployeeStatutoryDeductionProfilesCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("EmployeeStatutoryDeductionProfilesUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([employeeId, effectiveFrom])
