{
  "name": "zmstore-pos-2",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "qa:auth:business-flow:browser-session": "tsx scripts/qa/auth/auth-business-flow-browser-session.ts",
    "qa:auth:login-otp-session:setup": "tsx scripts/qa/auth/auth-login-otp-session-setup.ts",
    "qa:auth:login-otp-session:cleanup": "tsx scripts/qa/auth/auth-login-otp-session-cleanup.ts",
    "qa:auth:role-routing:setup": "tsx scripts/qa/auth/auth-role-routing-setup.ts",
    "qa:auth:role-routing:cleanup": "tsx scripts/qa/auth/auth-role-routing-cleanup.ts",
    "qa:cashier:shift-open-close:happy-path:setup": "tsx scripts/qa/cashier/cashier-shift-open-close-happy-path-setup.ts",
    "qa:cashier:shift-open-close:happy-path:cleanup": "tsx scripts/qa/cashier/cashier-shift-open-close-happy-path-cleanup.ts",
    "qa:workforce:payroll:happy-path:setup": "tsx scripts/qa/workforce/workforce-payroll-happy-path-setup.ts",
    "qa:workforce:payroll:happy-path:browser-session": "tsx scripts/qa/workforce/workforce-payroll-happy-path-browser-session.ts",
    "qa:workforce:payroll:happy-path:cleanup": "tsx scripts/qa/workforce/workforce-payroll-happy-path-cleanup.ts",
    "automation:flow:setup": "node scripts/automation/business-flow/index.mjs setup",
    "automation:flow:smoke": "node scripts/automation/business-flow/index.mjs smoke",
    "automation:flow:cleanup": "node scripts/automation/business-flow/index.mjs cleanup",
    "ui:test": "npm exec --yes --package=@playwright/test -- playwright test --config=playwright.config.ts",
    "ui:test:cashier:shift-open-close:happy-path": "QA_CASHIER_SHIFT_OPEN_CLOSE_HAPPY_PATH_ENABLE=1 npm exec --yes --package=@playwright/test -- playwright test --config=playwright.config.ts --project=cashier-shift-open-close-happy-path",
    "ui:test:workforce:payroll:happy-path": "QA_WORKFORCE_PAYROLL_HAPPY_PATH_ENABLE=1 npm exec --yes --package=@playwright/test -- playwright test --config=playwright.config.ts --project=workforce-payroll-happy-path",
    "ui:test:update": "npm exec --yes --package=@playwright/test -- playwright test --config=playwright.config.ts --update-snapshots",
    "ui:cycle": "node scripts/automation/run-ui-cycle.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.864.0",
    "@faker-js/faker": "^9.9.0",
    "@prisma/client": "^6.11.1",
    "@remix-run/node": "^2.16.8",
    "@remix-run/react": "^2.16.8",
    "@remix-run/serve": "^2.16.8",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "isbot": "^4.1.0",
    "nodemailer": "^8.0.1",
    "prisma": "^6.11.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@remix-run/dev": "^2.16.8",
    "@remix-run/serve": "^2.16.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.38.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.38",
    "remix": "^2.17.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.20.3",
    "typescript": "^5.1.6",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^4.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
